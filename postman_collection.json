{
  "info": {
    "name": "Travel Planner API",
    "description": "CRUD API for managing travel projects and places sourced from the Art Institute of Chicago.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{username}}", "type": "string" },
      { "key": "password", "value": "{{password}}", "type": "string" }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "username",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "password",
      "value": "secret",
      "type": "string"
    },
    {
      "key": "project_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "place_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/", "host": ["{{base_url}}"], "path": ["projects", ""] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Italy Trip\",\n  \"description\": \"Two weeks in northern Italy\",\n  \"start_date\": \"2025-06-01\"\n}"
            }
          }
        },
        {
          "name": "Create project with places",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/", "host": ["{{base_url}}"], "path": ["projects", ""] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Chicago Art Tour\",\n  \"description\": \"Exploring the Art Institute of Chicago\",\n  \"places\": [\n    { \"external_id\": 16568 },\n    { \"external_id\": 16571 }\n  ]\n}"
            }
          }
        },
        {
          "name": "List projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/?offset=0&limit=20",
              "host": ["{{base_url}}"],
              "path": ["projects", ""],
              "query": [
                { "key": "offset", "value": "0" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}"]
            }
          }
        },
        {
          "name": "Update project",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Updated Trip Name\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete project",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Art Institute of Chicago (find artwork IDs)",
      "item": [
        {
          "name": "Search artworks",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": {
              "raw": "https://api.artic.edu/api/v1/artworks/search?q=monet&fields=id,title&limit=10",
              "protocol": "https",
              "host": ["api", "artic", "edu"],
              "path": ["api", "v1", "artworks", "search"],
              "query": [
                { "key": "q", "value": "monet", "description": "Search term — change to anything" },
                { "key": "fields", "value": "id,title" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Use the 'id' field from results as 'external_id' when creating projects or adding places."
          }
        },
        {
          "name": "Get artwork by ID",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": {
              "raw": "https://api.artic.edu/api/v1/artworks/16568?fields=id,title",
              "protocol": "https",
              "host": ["api", "artic", "edu"],
              "path": ["api", "v1", "artworks", "16568"],
              "query": [
                { "key": "fields", "value": "id,title" }
              ]
            },
            "description": "Verify a specific artwork exists. Replace 16568 with any artwork ID."
          }
        }
      ]
    },
    {
      "name": "Places",
      "item": [
        {
          "name": "Add place to project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"external_id\": 16568\n}"
            }
          }
        },
        {
          "name": "List places in project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places"]
            }
          }
        },
        {
          "name": "Get place",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places/{{place_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places", "{{place_id}}"]
            }
          }
        },
        {
          "name": "Update place notes",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places/{{place_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places", "{{place_id}}"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"notes\": \"Must visit the Impressionism gallery first!\"\n}"
            }
          }
        },
        {
          "name": "Mark place as visited",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places/{{place_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places", "{{place_id}}"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"visited\": true\n}"
            }
          }
        }
      ]
    }
  ]
}
